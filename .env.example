# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Telegram broadcast channel id used by the growth loop (e.g. -1001234567890)
HEARTH_CHANNEL_ID=

# Telegram crowd-sourcing group id used for crowd questions (e.g. -1009876543210)
HEARTH_CROWD_GROUP_ID=

# Path to the local SQLite database file
DB_PATH=hearth.db
