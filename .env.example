# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Which LLM backend to use: gemini or openai
LLM_BACKEND=gemini

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Cheap Responses API model that supports hosted web search
OPENAI_MODEL=gpt-5.4-mini

# Telegram broadcast channel id used by the growth loop (e.g. -1001234567890)
HEARTH_CHANNEL_ID=

# Telegram crowd-sourcing group id used for crowd questions (e.g. -1009876543210)
HEARTH_CROWD_GROUP_ID=

# Path to the local SQLite database file
DB_PATH=hearth.db
